# Root-level .env.example — copy relevant sections into web/.env and api/.env
# 각 서브 패키지의 .env.example을 참고하세요.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key          # 클라이언트(브라우저) 허용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # 서버 전용 — 절대 노출 금지
SUPABASE_SCHEMA=dev                      # 개발은 dev 스키마를 사용해 운영 public과 분리

# ---- Storage (S3-compatible) ----
STORAGE_ENDPOINT_URL=
STORAGE_BUCKET=editluma-uploads
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_REGION=ap-northeast-2

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Credits ----
INITIAL_USER_CREDITS=100
IMAGE_REQUEST_CREDIT_COST=10
WEB_APP_URL=http://localhost:3001
PRESIGN_UPLOAD_EXPIRY_SECONDS=300
PRESIGN_DOWNLOAD_EXPIRY_SECONDS=3600

# ---- AI ----
IDEOGRAM_API_KEY=
IDEOGRAM_BASE_URL=https://api.ideogram.ai
IDEOGRAM_MODEL=V_2
IDEOGRAM_TIMEOUT_MS=120000
GROQ_API_KEY=

# ---- Polar Billing ----
# ENVIRONMENT=production 인 경우 반드시 production 으로 설정
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_STARTER=
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_MAX=
POLAR_CHECKOUT_LINK_STARTER=
POLAR_CHECKOUT_LINK_PRO=
POLAR_CHECKOUT_LINK_MAX=

# ---- Next.js (web/.env) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 로컬 개발: 비워두면 Next.js 프록시 사용(CORS 없음). 원격 API 시에만 절대 URL 입력.
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://localhost:8010
