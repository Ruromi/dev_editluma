# ---- Supabase ----
# Project URL (공개 가능)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — 브라우저에서 사용 (공개 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — 서버 전용, 절대 브라우저에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 개발은 dev 스키마를 사용해 운영 public 스키마와 분리
SUPABASE_SCHEMA=dev

# ---- API ----
# 로컬 개발: 비워두면 Next.js 내장 프록시(/api/* → FastAPI)를 사용하므로 CORS 불필요.
# 원격 API 사용 시에만 절대 URL을 입력하세요 (예: https://api.editluma.com).
NEXT_PUBLIC_API_URL=
# Next.js 서버가 FastAPI를 프록시할 때 사용하는 내부 URL (브라우저 비노출).
INTERNAL_API_URL=http://localhost:8010

# ---- Access Control (비공개 값, 실제 값 커밋 금지) ----
# raw IP/email 또는 SHA-256 해시 목록 중 하나만 사용하세요. 여러 값은 쉼표로 구분합니다.
DEV_ALLOWED_IPS=
DEV_ALLOWED_IP_HASHES=
ADMIN_ALLOWED_IPS=
ADMIN_ALLOWED_IP_HASHES=
ADMIN_EMAILS=
ADMIN_EMAIL_HASHES=

# Polar 결제 설정은 api/.env 쪽에서 관리합니다.
